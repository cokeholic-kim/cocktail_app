{
  "name": "cocktail_app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev --turbopack",
    "build": "next build --webpack",
    "build:turbopack": "next build --turbopack",
    "typecheck": "tsc --noEmit",
    "check:pr-gate": "npm run lint && npm run typecheck && npm run build",
    "check:ci": "npm run lint && npm run typecheck && npm run build",
    "check:deps-compat": "node ./scripts/check-deps-compat.js",
    "check:deploy-gate": "powershell -ExecutionPolicy Bypass -File .\\scripts\\p0-deploy-gate.ps1",
    "check:p0-smoke": "powershell -ExecutionPolicy Bypass -File .\\scripts\\p0-smoke-tests.ps1",
    "check:upgrade-regression": "npm run lint && npm run build && npm run check:p0-smoke",
    "check:security-audit": "npm audit --audit-level=high --omit=dev",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "start": "next start",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "cookies-next": "^6.1.1",
    "js-cookie": "^3.0.5",
    "next": "16.1.6",
    "next-pwa": "^5.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
